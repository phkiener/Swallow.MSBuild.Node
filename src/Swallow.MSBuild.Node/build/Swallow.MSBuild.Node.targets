<Project>

  <Target Name="_FrontendRestore" BeforeTargets="restore" DependsOnTargets="_InstallDependencies" />
  <Target Name="_FrontendBuild" BeforeTargets="PrepareForBuild" DependsOnTargets="_RunBuildScript" />
  <Target Name="_FrontendResolveStaticWebAssets" DependsOnTargets="_IncludeFrontendBuildAssets" />
  <Target Name="_FrontendClean" BeforeTargets="Clean" DependsOnTargets="_RemoveInstalledPackages;_CleanFrontendOutputs" />

  <PropertyGroup>
    <FrontendPackagePath>$(FrontendRootPath)node_modules/</FrontendPackagePath>
  </PropertyGroup>

  <ItemGroup>
    <FrontendConfig Include="$(FrontendRootPath)package.json" />
    <FrontendConfig Include="$(FrontendRootPath)package-lock.json" />

    <!-- JS & TS-->
    <FrontendBuild Include="$(FrontendRootPath)**/*.js" />
    <FrontendBuild Include="$(FrontendRootPath)**/*.jsx" />
    <FrontendBuild Include="$(FrontendRootPath)**/*.ts" />
    <FrontendBuild Include="$(FrontendRootPath)**/*.tsx" />

    <!-- Common CSS preprocessors -->
    <FrontendBuild Include="$(FrontendRootPath)**/*.scss" />
    <FrontendBuild Include="$(FrontendRootPath)**/*.sass" />
    <FrontendBuild Include="$(FrontendRootPath)**/*.less" />
    <FrontendBuild Include="$(FrontendRootPath)**/*.styl" />

  </ItemGroup>

  <ItemGroup>
    <!-- So that the source files (and node_modules) are *definitely* not included in any pack/publish output. -->
    <Content Remove="@(FrontendConfig)" />
    <Content Remove="@(FrontendBuild)" />
    <Content Remove="$(FrontendPackagePath)**/*" />

    <!-- To make sure the files show up in IDEs -->
    <None Include="@(FrontendConfig)" />
    <None Include="@(FrontendBuild)" />
  </ItemGroup>

  <!-- SETUP -->

  <Target Name="_SetupFrontendBuild" Condition="EXISTS('$(FrontendRootPath)package.json')">
    <PropertyGroup>
      <!-- Set here because we can't get IntermediateOutputPath any earlier -->
      <FrontendOutputPath Condition="$(FrontendOutputPath) == ''">$(MSBuildProjectDirectory)/$(IntermediateOutputPath)dist/</FrontendOutputPath>
    </PropertyGroup>

    <ItemGroup>
      <_DependencyInstallStamp Include="$(MSBuildProjectDirectory)/$(BaseIntermediateOutputPath)npm-install.stamp" />
      <_FrontendBuildStamp Include="$(MSBuildProjectDirectory)/$(IntermediateOutputPath)npm-build.stamp" />

      <_FrontendBuildInput Include="@(FrontendConfig)" Exclude="$(FrontendBuildExcludes);$(FrontendPackagePath)**/*;$(BaseIntermediateOutputPath)**/*;$(BaseOutputPath)**/*;" />
      <_FrontendBuildInput Include="@(FrontendBuild)" Exclude="$(FrontendBuildExcludes);$(FrontendPackagePath)**/*;$(BaseIntermediateOutputPath)**/*;$(BaseOutputPath)**/*;" />
    </ItemGroup>
  </Target>

  <!-- RESTORE -->

  <Target Name="_RemoveInstalledPackages" DependsOnTargets="_SetupFrontendBuild" BeforeTargets="_InstallDependencies" Condition="$(RestoreForce) == 'true' AND EXISTS('$(FrontendRootPath)package.json')">
    <RemoveDir Directories="$(FrontendPackagePath)" />
    <Delete Files="@(_DependencyInstallStamp)" />
  </Target>

  <Target Name="_InstallDependencies" DependsOnTargets="_SetupFrontendBuild" Inputs="@(FrontendConfig)" Outputs="@(_DependencyInstallStamp)" Condition="EXISTS('$(FrontendRootPath)package.json')">
    <Exec Command="$(BuildToolPath) install" EchoOff="true" WorkingDirectory="$(FrontendRootPath)" />
    <WriteLinesToFile File="@(_DependencyInstallStamp)" Lines="$([System.DateTime]::Now.ToBinary())" />
  </Target>

  <!-- BUILD -->

  <Target Name="_RunBuildScript" DependsOnTargets="_InstallDependencies" Inputs="@(_FrontendBuildInput)" Outputs="@(_FrontendBuildStamp)" Condition="EXISTS('$(FrontendRootPath)package.json')">
    <MakeDir Directories="$(FrontendOutputPath)" />

    <Exec Command="$(BuildToolPath) run --if-present $(BuildScriptName)"
          EnvironmentVariables="OUT_DIR=$(FrontendOutputPath)"
          EchoOff="true"
          WorkingDirectory="$(FrontendRootPath)" />

    <WriteLinesToFile File="@(_FrontendBuildStamp)" Lines="$([System.DateTime]::Now.ToBinary())" />
  </Target>

  <Target Name="_IncludeFrontendBuildAssets" DependsOnTargets="_FrontendBuild" Condition="EXISTS('$(FrontendRootPath)package.json')">
    <ItemGroup>
      <_FrontendOutput Include="$(FrontendOutputPath)**/*" />
    </ItemGroup>
    <DefineStaticWebAssets
      CandidateAssets="@(_FrontendOutput->Distinct())"
      RelativePathPattern="$(FrontendOutputPath)**/*"
      ContentRoot="$(FrontendOutputPath)"
      BasePath="$(StaticWebAssetBasePath)"
      SourceType="Computed"
      SourceId="$(PackageId)"
      AssetMergeSource="$(StaticWebAssetMergeTarget)"
    >
      <Output TaskParameter="Assets" ItemName="StaticWebAsset" />
      <Output TaskParameter="Assets" ItemName="_CurrentProjectStaticWebAsset" />
    </DefineStaticWebAssets>

    <DefineStaticWebAssetEndpoints
      CandidateAssets="@(_CurrentProjectStaticWebAsset)"
      ExistingEndpoints="@(StaticWebAssetEndpoint)"
      ContentTypeMappings="@(StaticWebAssetContentTypeMapping)">
      <Output TaskParameter="Endpoints" ItemName="StaticWebAssetEndpoint" />
    </DefineStaticWebAssetEndpoints>
  </Target>

  <!-- CLEAN -->

  <Target Name="_CleanFrontendOutputs" DependsOnTargets="_SetupFrontendBuild" Condition="EXISTS('$(FrontendRootPath)package.json')">
    <Exec Command="$(BuildToolPath) run --if-present $(CleanScriptName)"
          EnvironmentVariables="OUT_DIR=$(FrontendOutputPath)"
          EchoOff="true"
          WorkingDirectory="$(FrontendRootPath)" />

    <RemoveDir Directories="$(FrontendOutputPath)" />
    <Delete Files="@(_FrontendBuildStamp)" />
  </Target>

</Project>
