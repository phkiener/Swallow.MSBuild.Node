<Project>

  <PropertyGroup>
    <FrontendRootDir>$(MSBuildProjectDirectory)/</FrontendRootDir>

    <BuildToolPath>npm</BuildToolPath>
    <BuildScriptName>build</BuildScriptName>
    <CleanScriptName>clean</CleanScriptName>

    <!--
      All JS-adjacent files (JavaScript, TypeScript and their React variants for good measure) are
      considered build-relevant.

      By default, we exclude all files in wwwroot/ from our build.
      This means they will stay untouched in <Content> and have no impact on
      the incremental build. They *might* be dependencies to the build nonetheless,
      we can't really detect that. It's up to the user to do that correctly.
    -->
    <FrontendCompilePatterns>*.js;*.jsx;*.ts;*.tsx</FrontendCompilePatterns>
    <FrontendCompileExcludes>wwwroot/**/*</FrontendCompileExcludes>
  </PropertyGroup>

  <PropertyGroup>
    <!-- https://github.com/dotnet/sdk/blob/bd75158074f6bcba0e58c22ceb13bdd3eb85c473/src/StaticWebAssetsSdk/Architecture.md -->
    <GenerateComputedBuildStaticWebAssetsDependsOn>_IncludeFrontendBuildAssets;$(GenerateComputedBuildStaticWebAssetsDependsOn)</GenerateComputedBuildStaticWebAssetsDependsOn>
    <GenerateComputedPublishStaticWebAssetsDependsOn>_IncludeFrontendBuildAssets;$(GenerateComputedPublishStaticWebAssetsDependsOn)</GenerateComputedPublishStaticWebAssetsDependsOn>
  </PropertyGroup>

</Project>
